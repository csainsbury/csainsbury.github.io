---
import Layout from '../layouts/Layout.astro';
import publicationsData from '../data/publications.json';

const papers = publicationsData.items;

const software = [
  {
    title: 'trial-emulation',
    status: 'PyPI package',
    description:
      'A Python package for target trial emulation and causal analysis of observational time-to-event data, ported from the TrialEmulation R package. It supports person-time / nested-trial workflows and marginal structural model analyses for research using routinely collected health data.',
    links: [
      { label: 'PyPI', href: 'https://pypi.org/project/trial-emulation/' },
      { label: 'GitHub', href: 'https://github.com/csainsbury/Trial-Emulation-R2P' },
    ],
    tags: ['target trial emulation', 'causal inference', 'time-to-event data', 'Python'],
  },
  {
    title: 'NEXUS scientific-discovery system',
    status: 'Research prototype',
    description:
      'An experimental system for reasoning about cross-domain method transfer: where a technique, representation, or design pattern from one field might plausibly unlock progress in another. The emphasis is on grounded discovery support rather than generic brainstorming.',
    links: [],
    tags: ['method transfer', 'scientific discovery', 'research intelligence'],
  },
  {
    title: 'pi / cog project and synthesis workflows',
    status: 'Research infrastructure',
    description:
      'A local knowledge and agent-workflow environment for keeping sources, tasks, synthesis pages, ideas, daily context, and project state connected. It is designed to make long-running research threads easier to resume, review, and develop over time.',
    links: [],
    tags: ['project memory', 'synthesis', 'agent workflows'],
  },
  {
    title: 'Source-ingest and project-state tooling',
    status: 'Workflow tooling',
    description:
      'Small scripts and routines for ingesting papers or transcripts, searching the maintained wiki, drafting task candidates, refreshing daily views, reviewing public-site updates, and preserving chronological work logs from Cog activity.',
    links: [],
    tags: ['source ingest', 'task extraction', 'daily review', 'work logs'],
  },
];
---

<Layout title="Outputs — Chris Sainsbury" currentPath="/outputs">
  <section class="page-header copy">
    <div class="eyebrow">outputs</div>
    <h1>Selected outputs</h1>
    <p class="lead">
      Recent papers, preprints, scholarly outputs, and software. The publication list is seeded from
      my public Google Scholar profile and kept deliberately simple for now.
    </p>
    <p class="small">
      Last refreshed: {publicationsData.lastRefreshed}. Full profile:
      <a href={publicationsData.sourceUrl} target="_blank" rel="noreferrer">Google Scholar</a>.
    </p>
  </section>

  <section class="grid two">
    <div class="panel section">
      <h2>Papers/preprints</h2>
      <div class="list publications-list">
        {papers.map((paper) => (
          <article class="list-item publication-item">
            <div class="publication-meta">
              <span class="status">{paper.year}</span>
              {paper.citedBy && <span class="small">Cited by {paper.citedBy}</span>}
            </div>
            <h3>{paper.title}</h3>
            <p class="muted">{paper.authors}</p>
            <p>{paper.venue}</p>
          </article>
        ))}
      </div>
    </div>

    <aside class="stack">
      <div class="panel section">
        <h2>Software and infrastructure</h2>
        <div class="list software-list">
          {software.map((item) => (
            <article class="list-item software-item">
              <div class="publication-meta">
                <span class="status">{item.status}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              {item.links.length > 0 && (
                <div class="tag-list">
                  {item.links.map((link) => (
                    <a class="tag" href={link.href} target="_blank" rel="noreferrer">
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
              <div class="tag-list">
                {item.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="panel section copy">
        <h2>Publication updates</h2>
        <p>
          This page currently uses a static snapshot rather than live Google Scholar scraping. A
          monthly update check can be added later, ideally by opening a review issue or pull request
          when new publications appear.
        </p>
      </div>
    </aside>
  </section>
</Layout>
