---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Chris Sainsbury" currentPath="/about">
  <section class="page-header copy">
    <div class="eyebrow">about</div>
    <h1>About</h1>
    <p class="lead">
      Clinician-researcher working at the intersection of medicine, machine learning, and research software.
    </p>
    <p class="profile-note">GitHub profile: data analysis in diabetes · machine learning · sailing · based in Glasgow.</p>
  </section>

  <section class="grid two">
    <div class="panel section copy">
      <h2>Short bio</h2>
      <p>
        Chris Sainsbury works across clinical medicine, AI, and research infrastructure. His work includes foundation models for electronic health records, mechanistic interpretability, translational clinical AI, and tools for organising and accelerating research.
      </p>
      <p>
        This site is intended as a simple public front page rather than a full institutional profile:
        a place to see active projects, recent outputs, and the overall shape of the portfolio.
      </p>
    </div>

    <div class="panel section">
      <h2>Affiliations and roles</h2>
      <div class="list">
        <div class="list-item">
          <strong>University of Dundee</strong>
          <p>Honorary Clinical Reader</p>
        </div>
        <div class="list-item">
          <strong>University of Birmingham</strong>
          <p>Honorary Senior Research Fellow</p>
        </div>
        <div class="list-item">
          <strong>University of Glasgow</strong>
          <p>Honorary Clinical Senior Lecturer</p>
        </div>
        <div class="list-item">
          <strong>NHS Greater Glasgow and Clyde</strong>
          <p>Consultant Physician in Diabetes and Endocrinology</p>
        </div>
        <div class="list-item">
          <strong>Public profiles</strong>
          <p>GitHub: csainsbury · ORCID available · website link to glucose.ai</p>
        </div>
      </div>
    </div>
  </section>

  <section class="grid two" style="margin-top: 1rem;">
    <div class="panel section">
      <h2>Areas of interest</h2>
      <div class="tag-list">
        <span class="tag">Clinical foundation models</span>
        <span class="tag">EHR language and representation</span>
        <span class="tag">Mechanistic interpretability</span>
        <span class="tag">Translational AI</span>
        <span class="tag">Research software</span>
        <span class="tag">Scientific discovery systems</span>
      </div>
    </div>

    <div class="panel section">
      <h2>Contact</h2>
      <p>Email: <a href="mailto:chris@sainsbury.im">chris@sainsbury.im</a></p>
      <p>GitHub: <a href="https://github.com/csainsbury/" target="_blank" rel="noreferrer">github.com/csainsbury</a></p>
      <p>glucose.ai: <a href="https://glucose.ai" target="_blank" rel="noreferrer">glucose.ai</a></p>
      <p>ORCID: <a href="https://orcid.org/0000-0002-7984-5721" target="_blank" rel="noreferrer">0000-0002-7984-5721</a></p>
      <p class="muted">Additional profile links can be added after review.</p>
    </div>
  </section>
</Layout>
