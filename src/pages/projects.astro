---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    id: 'phenotype-fingerprinting',
    title: 'Phenotype fingerprinting',
    status: 'Translational research thread',
    summary:
      'A line of work using clinical sequence models to identify rare, under-recognised, or hard-to-characterise disease patterns.',
    aims: 'The aim is to use latent clinical trajectories to surface patients or cohorts whose records contain early, partial, or indirect evidence of a phenotype before conventional coding makes it obvious. This work is intended to support earlier recognition, better cohort definition, and more testable translational hypotheses.',
    links: ['Clinical sequence modelling', 'Rare-case and under-recognised phenotype discovery'],
  },
  {
    id: 'orca',
    title: 'ORCA',
    status: 'Research programme',
    summary:
      'A programme built around the idea that electronic health records can be treated as a language, with implications for representation, translation, and generation.',
    aims: 'The aim is to move beyond treating EHRs as flat tables of variables and instead study the statistical structure, translation behaviour, and generative possibilities of clinical event sequences. ORCA asks whether coded records can be read, aligned across systems, translated into clinical language, and used to reason about plausible futures.',
    links: ['Working paper in progress', 'Language-of-EHR framing'],
  },
  {
    id: 'nexus',
    title: 'NEXUS',
    status: 'Scientific-discovery system',
    summary:
      'A system for predicting cross-domain scientific method transfer using historical discoveries and validated transfers.',
    aims: 'The aim is to build a system that learns from previous scientific discoveries to suggest where methods, representations, or experimental ideas may transfer next. NEXUS is intended as a grounded discovery assistant: less about generic brainstorming, more about structured evidence for why a method from one domain may work in another.',
    links: ['Methods whitepaper in draft', 'Discovery-system thread'],
  },
  {
    id: 'ascend',
    title: 'ASCEND research arc',
    status: 'Programme-level thread',
    summary:
      'A broader research arc spanning ASCENDgpt, FlatASCEND, and ORCA, focused on modelling structured clinical trajectories.',
    aims: 'The aim is to develop a coherent sequence of EHR foundation-model work: from phenotype-aware representation learning, through autoregressive clinical trajectory generation, to interpretation and language-like translation. The arc is designed to make clinical sequences modelable, inspectable, and ultimately more useful for real clinical research questions.',
    links: ['ASCENDgpt', 'FlatASCEND', 'ORCA'],
  },
  {
    id: 'glucose-ai',
    title: 'glucose.ai',
    status: 'Public-facing project',
    summary:
      'A literature intelligence and discovery surface for diabetes and AI / machine learning work.',
    aims: 'The aim is to make the diabetes and AI literature easier to monitor, search, and turn into useful research leads. glucose.ai acts as a public-facing discovery surface for papers, themes, and emerging methods in diabetes, metabolic medicine, and clinical AI.',
    links: ['Public website', 'Diabetes + AI / ML discovery'],
  },
  {
    id: 'pi-cog',
    title: 'pi / cog workflows',
    status: 'Research infrastructure',
    summary:
      'Research and coding infrastructure for organising sources, tasks, synthesis, and project state in a more usable system.',
    aims: 'The aim is to make complex research work easier to run: keeping sources, tasks, synthesis, code, experiments, and project state connected enough that ideas can develop over time rather than being lost. Current patterns include Physarum-style scout waves for exploring uncertain research routes, outcome loops for rubric-based artifact evaluation, and Nightshift routines for daily review, continuity, and safe background progress.',
    links: ['Physarum scout waves', 'Outcome loops', 'Nightshift / work-log', 'Agent-supported research workflows'],
  },
];
---

<Layout title="Projects — Chris Sainsbury" currentPath="/projects">
  <section class="page-header copy">
    <div class="eyebrow">projects</div>
    <h1>Active projects</h1>
    <p class="lead">
      A small set of the main projects and programmes currently shaping the portfolio, spanning academic research, translational work, public-facing tools, and research infrastructure.
    </p>
  </section>

  <section class="grid two">
    {projects.map((project) => (
      <article class="panel card" id={project.id}>
        <div class="status">{project.status}</div>
        <h2>{project.title}</h2>
        <p>{project.summary}</p>
        <p>{project.aims}</p>
        <div class="tag-list">
          {project.links.map((link) => (
            <span class="tag">{link}</span>
          ))}
        </div>
      </article>
    ))}
  </section>
</Layout>
